{
  "name": "@tejgor/deckhand",
  "version": "0.1.2",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "DECKHAND_DEV=1 node --import tsx src/cli.ts",
    "daemon": "DECKHAND_DEV=1 node --import tsx src/cli.ts --daemon",
    "build": "tsc -p tsconfig.json",
    "postbuild": "chmod +x dist/cli.js",
    "start": "node dist/cli.js",
    "postinstall": "node scripts/fix-node-pty.js",
    "prepare": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tejgor/deckhand.git"
  },
  "bugs": {
    "url": "https://github.com/tejgor/deckhand/issues"
  },
  "homepage": "https://github.com/tejgor/deckhand#readme",
  "license": "MIT",
  "keywords": [
    "agent",
    "cli",
    "terminal",
    "workbench",
    "ink",
    "worktree"
  ],
  "dependencies": {
    "@xterm/headless": "^5.5.0",
    "ink": "^6.3.1",
    "node-pty": "^1.1.0",
    "react": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  },
  "description": "A lightweight agent workbench for your IDE terminal.",
  "bin": {
    "deckhand": "dist/cli.js"
  },
  "files": [
    "dist",
    "scripts",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "os": [
    "darwin",
    "linux"
  ]
}
